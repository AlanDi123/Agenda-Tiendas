# ============================================
# DOMMUSS AGENDA BACKEND - ENVIRONMENT
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
CORS_ORIGIN=https://agenda-tienda.vercel.app

# ============================================
# DATABASE
# ============================================
# PostgreSQL (production)
DATABASE_URL="postgresql://user:password@localhost:5432/dommuss_agenda?schema=public"

# SQLite (development only - uncomment to use)
# DATABASE_URL="file:./dev.db"

# ============================================
# SECURITY - HMAC KEYS FOR WEBHOOKS
# Generate with: openssl rand -hex 32
# ============================================
WEBHOOK_SECRET="your-master-webhook-secret-min-32-chars"

# Individual gateway secrets (recommended for production)
MERCADO_PAGO_WEBHOOK_SECRET="mp-webhook-secret"
PAYPAL_WEBHOOK_SECRET="paypal-webhook-secret"
EBANX_WEBHOOK_SECRET="ebanx-webhook-secret"
MOBBEX_WEBHOOK_SECRET="mobbex-webhook-secret"
PAYWAY_WEBHOOK_SECRET="payway-webhook-secret"

# ============================================
# PAYMENT GATEWAY API KEYS
# ============================================
MERCADO_PAGO_ACCESS_TOKEN="APP_USR-xxx-xxx"
PAYPAL_CLIENT_ID="paypal-client-id"
PAYPAL_CLIENT_SECRET="paypal-client-secret"
EBANX_PRIVATE_KEY="ebanx-private-key"
MOBBEX_API_KEY="mobbex-api-key"
MOBBEX_ACCESS_TOKEN="mobbex-access-token"
PAYWAY_MERCHANT_ID="payway-merchant-id"
PAYWAY_PRIVATE_KEY="payway-private-key"

# ============================================
# SUBSCRIPTION SETTINGS
# ============================================
GRACE_PERIOD_HOURS=72
FREE_TRIAL_DAYS=7

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
