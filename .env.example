# ============================================
# DOMMUSS AGENDA - Environment Variables
# ============================================
# Copiar este archivo a .env y completar los valores
# NUNCA commitear el archivo .env con valores reales

# ============================================
# BACKEND API (Vercel / Render / Railway)
# ============================================

# Puerto del servidor (solo para desarrollo local)
PORT=3001
NODE_ENV=development

# CORS: orígenes permitidos (coma, sin espacios o con espacios — el backend hace trim).
# Se unen a la lista por defecto (incluye agenda-tienda y agenda-tiendas en Vercel).
# No dejar vacío: en despliegues antiguos "" hacía fallar el preflight.
# CORS_ORIGIN (singular) también se acepta como un origen extra.
# CORS_ORIGINS=https://agenda-tienda.vercel.app,https://agenda-tiendas.vercel.app

# Base de datos Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT Secret (generar uno nuevo: openssl rand -hex 32)
JWT_SECRET=tu_jwt_secreto_aqui_minimo_32_caracteres

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email de contacto
CONTACT_EMAIL=contacto@tu-dominio.com

# ============================================
# MERCADO PAGO (Producción)
# ============================================

# Public Key (frontend y backend)
MERCADO_PAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Access Token (solo backend)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret (se configura después de crear la app en MP)
MERCADO_PAGO_WEBHOOK_SECRET=tu_webhook_secret_aqui

# ============================================
# APP VERSION (OTA Updates)
# ============================================

# Versión actual de la app
APP_LATEST_VERSION=1.0.0
APP_VERSION_CODE=10000
APP_UPDATE_MANDATORY=false
APP_MIN_VERSION=1.0.0

# URL del bundle.zip para OTA (GitHub Releases)
APP_BUNDLE_URL=https://github.com/tu-usuario/tu-repo/releases/latest/download/bundle.zip

# Changelog visible en el modal de actualización
APP_CHANGELOG=Nueva versión disponible

# Fecha de publicación (ISO 8601)
APP_PUBLISHED_AT=2025-01-01T00:00:00.000Z

# ============================================
# DEPLOY SECRET (CI/CD)
# ============================================

# Secret para que GitHub Actions notifique al backend
# Generar con: openssl rand -hex 32
DEPLOY_SECRET=tu_deploy_secret_aqui_minimo_32_caracteres

# ============================================
# FRONTEND (Vite - Vercel)
# ============================================

# URL del backend en producción (CON "s" en agenda-tiendas)
VITE_API_URL=https://agenda-tiendas.vercel.app

# ============================================
# ANDROID KEYSTORE (GitHub Secrets)
# ============================================
# Estos NO van en .env, se configuran en GitHub Actions Secrets:
#
# ANDROID_KEYSTORE_BASE64=<contenido del keystore en base64>
# ANDROID_KEYSTORE_PASSWORD=<password del keystore>
# ANDROID_KEY_PASSWORD=<password de la key>
# ANDROID_KEY_ALIAS=<alias de la key>
#
# Para obtener el base64:
# base64 -w 0 android/app/keystore.jks | pbcopy (macOS)
# o
# certutil -encode android/app/keystore.jks keystore.b64 (Windows)
